# ==========================================
# ADK Local Authentication & Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ==========================================

# ── Option A: Google AI Studio (Gemini Developer API) ─────────────────────────
# 1. Get a free API key from https://aistudio.google.com/
# 2. Uncomment and paste your key:
# GOOGLE_API_KEY="your_ai_studio_api_key_here"
# GOOGLE_GENAI_USE_VERTEXAI="false"

# ── Option B: Google Cloud / Vertex AI ────────────────────────────────────────
# 1. Install gcloud CLI: https://cloud.google.com/sdk/docs/install
# 2. Authenticate: gcloud auth application-default login
# 3. Fill in your project ID and uncomment:
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="global"
# GOOGLE_GENAI_USE_VERTEXAI="true"

# ── Agent tuning (optional) ────────────────────────────────────────────────────
# Dollar threshold below which expenses are auto-approved (default: 100.00)
# EXPENSE_THRESHOLD="100.00"

# Gemini model to use for risk reviews (default: gemini-3.1-flash-lite)
# EXPENSE_MODEL_NAME="gemini-3.1-flash-lite"
