# Normalize line endings to LF in the repo, checkout as native on each OS
* text=auto eol=lf

# Force LF for these file types regardless of OS
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
Makefile text eol=lf

# Binary files — no line ending conversion
*.db    binary
*.lock  binary
uv.lock text eol=lf
